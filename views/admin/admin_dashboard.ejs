<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trạm Đọc - Quản Lý Hệ Thống</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <script src="https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js"></script>
    <style>
        :root {
            --admin-primary: #154c2a;
            --admin-secondary: #1e824c;
        }
        body {
            background-color: #f4f7f6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .sidebar {
            background-color: var(--admin-primary);
            min-height: 100vh;
            color: white;
        }
        .sidebar a {
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            padding: 15px 20px;
            display: block;
            transition: 0.3s;
        }
        .sidebar a:hover, .sidebar a.active {
            background-color: var(--admin-secondary);
            color: white;
            border-left: 4px solid #fff;
        }
        .stat-card {
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            transition: 0.3s;
        }
        .stat-card:hover {
            transform: translateY(-5px);
        }
        .icon-box {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }
    </style>
</head>
<body>

<div class="container-fluid p-0">
    <div class="row g-0">
        <div class="col-md-2 sidebar d-none d-md-flex flex-column">
            <div class="p-4 text-center border-bottom border-secondary">
                <h4 class="fw-bold mb-0"><i class="fas fa-book-reader me-2"></i>TRẠM ĐỌC</h4>
                <small class="text-white-50">Nhà sách đám mây</small>
            </div>
            
            <nav class="mt-3 d-flex flex-column flex-grow-1">
                <a href="/admin/admin_dashboard" class="active"><i class="fas fa-chart-line me-2"></i> Tổng quan</a>
                <a href="/admin/admin_orders"><i class="fas fa-shopping-cart me-2"></i> Quản lý đơn hàng</a>
                <a href="/admin/admin_books"><i class="fas fa-book me-2"></i> Quản lý sách</a>
                <a href="/admin/admin_users"><i class="fas fa-users me-2"></i> Quản lý người dùng</a>
                <a href="/"><i class="fas fa-home me-2"></i> Về trang chủ</a>
                
                <a href="/dangxuat" class="mt-auto mb-4 text-warning fw-bold"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a>
            </nav>
        </div>

        <div class="col-md-10 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-success"><i class="fas fa-chart-line me-2"></i>TỔNG QUAN</h2>
                <div>
                    <span class="text-muted me-3"><i class="fas fa-user-circle"></i> Xin chào, <strong><%= session.fullname %></strong></span>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="card stat-card bg-white p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 fw-bold">TỔNG DOANH THU</p>
                                <h4 class="text-success fw-bold mb-0"><%= typeof totalRevenue !== 'undefined' ? totalRevenue.toLocaleString('vi-VN') : 0 %>đ</h4>
                            </div>
                            <div class="icon-box bg-success text-white bg-opacity-75">
                                <i class="fas fa-money-bill-wave"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stat-card bg-white p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 fw-bold">ĐƠN HOÀN THÀNH</p>
                                <h4 class="text-primary fw-bold mb-0"><%= typeof countCompleted !== 'undefined' ? countCompleted : 0 %></h4>
                            </div>
                            <div class="icon-box bg-primary text-white bg-opacity-75">
                                <i class="fas fa-check-circle"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stat-card bg-white p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 fw-bold">ĐƠN CHỜ DUYỆT</p>
                                <h4 class="text-warning fw-bold mb-0"><%= typeof countPending !== 'undefined' ? countPending : 0 %></h4>
                            </div>
                            <div class="icon-box bg-warning text-dark bg-opacity-75">
                                <i class="fas fa-clock"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card stat-card bg-white p-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1 fw-bold">SÁCH TRONG KHO</p>
                                <h4 class="text-info fw-bold mb-0"><%= typeof totalBooks !== 'undefined' ? totalBooks : 0 %></h4>
                            </div>
                            <div class="icon-box bg-info text-white bg-opacity-75">
                                <i class="fas fa-layer-group"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-success"><i class="fas fa-file-invoice-dollar me-2"></i>BÁO CÁO DOANH THU THEO NGÀY</h5>
                    <button onclick="exportToExcel('revenueTable')" class="btn btn-outline-success btn-sm fw-bold">
                        <i class="fas fa-file-excel me-1"></i> Xuất Excel
                    </button>
                </div>
                <div class="card-body">
                    <form action="/admin/admin_dashboard" method="GET" class="row g-3 align-items-end mb-4">
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold">Từ ngày:</label>
                            <input type="date" name="startDate" class="form-control" value="<%= typeof startDate !== 'undefined' ? startDate : '' %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold">Đến ngày:</label>
                            <input type="date" name="endDate" class="form-control" value="<%= typeof endDate !== 'undefined' ? endDate : '' %>">
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-success px-4"><i class="fas fa-filter me-2"></i> Lọc dữ liệu</button>
                            <a href="/admin/admin_dashboard" class="btn btn-light text-danger border ms-2"><i class="fas fa-redo"></i></a>
                        </div>
                    </form>

                    <div class="table-responsive">
                        <table id="revenueTable" class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Ngày hoàn thành</th>
                                    <th>Khách hàng</th>
                                    <th>Số lượng SP</th>
                                    <th>Doanh thu</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof revenueOrders !== 'undefined' && revenueOrders.length > 0) { %>
                                    <% let totalTable = 0; %>
                                    <% revenueOrders.forEach(order => { %>
                                        <% totalTable += order.totalAmount; %>
                                        <tr>
                                            <td class="fw-bold text-secondary">#<%= order._id.toString().slice(-6).toUpperCase() %></td>
                                            <td><%= new Date(order.orderDate).toLocaleDateString('vi-VN') %></td>
                                            <td><%= order.customerName %></td>
                                            <td>
                                                <% let qty = 0; order.items.forEach(i => qty += i.quantity); %>
                                                <%= qty %>
                                            </td>
                                            <td class="text-danger fw-bold"><%= order.totalAmount.toLocaleString('vi-VN') %>đ</td>
                                            <td><span class="badge bg-primary">Hoàn thành</span></td>
                                        </tr>
                                    <% }) %>
                                    <tr class="table-success fw-bold">
                                        <td colspan="4" class="text-end">TỔNG CỘNG TRONG KỲ:</td>
                                        <td class="text-danger fs-5"><%= totalTable.toLocaleString('vi-VN') %>đ</td>
                                        <td></td>
                                    </tr>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">Không có dữ liệu doanh thu trong khoảng thời gian này.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    function exportToExcel(tableId) {
        // Lấy bảng bằng ID
        var table = document.getElementById(tableId);
        // Chuyển HTML table thành worksheet
        var wb = XLSX.utils.table_to_book(table, {sheet: "DoanhThu"});
        // Tải file về máy
        XLSX.writeFile(wb, "BaoCao_DoanhThu_TramDoc.xlsx");
    }
</script>

</body>
</html>