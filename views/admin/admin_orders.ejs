<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý Đơn hàng - Admin Trạm Đọc</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        :root { --admin-primary: #154c2a; --admin-secondary: #1e824c; }
        body { background-color: #f4f7f6; font-family: 'Segoe UI', sans-serif; }
        .sidebar { background-color: var(--admin-primary); min-height: 100vh; color: white; }
        .sidebar a { color: rgba(255, 255, 255, 0.8); text-decoration: none; padding: 15px 20px; display: block; transition: 0.3s; }
        .sidebar a:hover, .sidebar a.active { background-color: var(--admin-secondary); color: white; border-left: 4px solid #fff; }
        .status-select { width: 140px; font-size: 13px; }
    </style>
</head>
<body>
<div class="container-fluid p-0">
    <div class="row g-0">
        <div class="col-md-2 sidebar d-none d-md-flex flex-column">
            <div class="p-4 text-center border-bottom border-secondary">
                <h4 class="fw-bold mb-0"><i class="fas fa-book-reader me-2"></i>TRẠM ĐỌC</h4>
                <small class="text-white-50">Nhà sách đám mây</small>
            </div>
       
            <nav class="mt-3 d-flex flex-column flex-grow-1">
                <a href="/admin/admin_dashboard"><i class="fas fa-chart-line me-2"></i> Tổng quan</a>
                <a href="/admin/admin_orders" class="active"><i class="fas fa-shopping-cart me-2"></i> Quản lý đơn hàng</a>
                <a href="/admin/admin_books"><i class="fas fa-book me-2"></i> Quản lý sách</a>
                <a href="/admin/admin_users"><i class="fas fa-users me-2"></i> Quản lý người dùng</a>
                <a href="/"><i class="fas fa-home me-2"></i> Về trang chủ</a>
                <a href="/dangxuat" class="mt-auto mb-4 text-warning fw-bold"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a>
            </nav>
        </div>

        <div class="col-md-10 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-success"><i class="fas fa-shopping-cart me-2"></i>QUẢN LÝ ĐƠN HÀNG</h2>
                <div>
                    <span class="text-muted"><i class="fas fa-user-circle"></i> Xin chào, <strong><%= session.fullname %></strong></span>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-success">
                                <tr>
                                    <th class="text-center">STT</th> <th>Khách hàng</th>
                                    <th>Ngày đặt</th>
                                    <th>Sản phẩm</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th>Hành động (Duyệt)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% orders.forEach((order, index) => { %>
                                <tr>
                                    <td class="text-center fw-bold text-muted"><%= index + 1 %></td>
                                    <td>
                                        <strong><%= order.customerName %></strong><br>
                                        <small class="text-muted"><%= order.phone %></small>
                                        <br><small class="text-muted"><%= order.address %></small>
                                    </td>
                                    <td><%= new Date(order.orderDate).toLocaleDateString('vi-VN') %></td>
                                    <td>
                                        <ul class="list-unstyled mb-0 small">
                                            <% order.items.forEach(item => { %>
                                                <li>• <%= item.title %> (x<%= item.quantity %>)</li>
                                            <% }) %>
                                        </ul>
                                    </td>
                                    <td class="text-danger fw-bold"><%= order.totalAmount.toLocaleString('vi-VN') %>đ</td>
                                    <td>
                                        <% if (order.status === 'Chờ duyệt' || order.status === 'Đang chờ duyệt') { %>
                                            <span class="badge bg-warning text-dark px-2 py-1 rounded-pill">Chờ duyệt</span>
                                        <% } else if (order.status === 'Đã duyệt' || order.status === 'Đang giao') { %>
                                            <span class="badge bg-success px-2 py-1 rounded-pill">Đã duyệt</span>
                                        <% } else if (order.status === 'Hoàn thành' || order.status === 'Đã hoàn thành') { %>
                                            <span class="badge bg-primary px-2 py-1 rounded-pill">Hoàn thành</span>
                                        <% } else if (order.status === 'Đã hủy') { %>
                                            <span class="badge bg-danger px-2 py-1 rounded-pill">Đã hủy</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <form action="/admin/admin_orders/update-status" method="POST" class="d-flex gap-2">
                                            <input type="hidden" name="orderId" value="<%= order._id %>">
                                            <select name="newStatus" class="form-select form-select-sm status-select">
                                                <option value="Đang chờ duyệt" <%= order.status === 'Đang chờ duyệt' || order.status === 'Chờ duyệt' ? 'selected' : '' %>>Chờ duyệt</option>
                                                <option value="Đã duyệt" <%= order.status === 'Đã duyệt' ? 'selected' : '' %>>Duyệt đơn</option>
                                                <option value="Đã hoàn thành" <%= order.status === 'Đã hoàn thành' || order.status === 'Hoàn thành' ? 'selected' : '' %>>Hoàn thành</option>
                                                <option value="Đã hủy" <%= order.status === 'Đã hủy' ? 'selected' : '' %>>Hủy đơn</option>
                                            </select>
                                            <button type="submit" class="btn btn-success btn-sm"><i class="fas fa-save"></i></button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<% if (typeof session !== 'undefined' && session.success) { %>
    <script>Swal.fire({ position: 'center', icon: 'success', title: '<%= session.success %>', showConfirmButton: false, timer: 2000 });</script>
<% } %>
<% if (typeof session !== 'undefined' && session.error) { %>
    <script>Swal.fire({ icon: 'error', title: 'Lỗi', text: '<%= session.error %>' });</script>
<% } %>
</body>
</html>