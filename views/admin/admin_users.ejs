<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản Lý Người Dùng - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        :root { --admin-primary: #154c2a; --admin-secondary: #1e824c; }
        body { background-color: #f4f7f6; font-family: 'Segoe UI', sans-serif; }
        .sidebar { background-color: var(--admin-primary); min-height: 100vh; color: white; }
        .sidebar a { color: rgba(255, 255, 255, 0.8); text-decoration: none; padding: 15px 20px; display: block; transition: 0.3s; }
        .sidebar a:hover, .sidebar a.active { background-color: var(--admin-secondary); color: white; border-left: 4px solid #fff; }
    </style>
</head>
<body>
<div class="container-fluid p-0">
    <div class="row g-0">
        <div class="col-md-2 sidebar d-none d-md-flex flex-column">
            <div class="p-4 text-center border-bottom border-secondary">
                <h4 class="fw-bold mb-0"><i class="fas fa-book-reader me-2"></i>TRẠM ĐỌC</h4>
                <small class="text-white-50">Nhà sách đám mây</small>
            </div>
            <nav class="mt-3 d-flex flex-column flex-grow-1">
                <a href="/admin/admin_dashboard"><i class="fas fa-chart-line me-2"></i> Tổng quan</a>
                <a href="/admin/admin_orders"><i class="fas fa-shopping-cart me-2"></i> Quản lý đơn hàng</a>
                <a href="/admin/admin_books"><i class="fas fa-book me-2"></i> Quản lý sách</a>
                <a href="/admin/admin_users" class="active"><i class="fas fa-users me-2"></i> Quản lý người dùng</a>
                <a href="/"><i class="fas fa-home me-2"></i> Về trang chủ</a>
                <a href="/dangxuat" class="mt-auto mb-4 text-warning fw-bold"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a>
            </nav>
        </div>

        <div class="col-md-10 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-success"><i class="fas fa-users me-2"></i>DANH SÁCH TÀI KHOẢN</h2>
                <div>
                    <span class="text-muted"><i class="fas fa-user-circle"></i> Xin chào, <strong><%= session.fullname %></strong></span>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-success">
                                <tr>
                                    <th>STT</th>
                                    <th>Họ và Tên</th>
                                    <th>Tên đăng nhập</th>
                                    <th>Email</th>
                                    <th>Quyền hạn</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach((user, index) => { %>
                                    <tr>
                                        <td class="fw-bold text-muted"><%= index + 1 %></td>
                                        <td class="fw-bold"><%= user.fullname %></td>
                                        <td>@<%= user.username %></td>
                                        <td><%= user.email %></td>
                                        <td>
                                            <% if (user.role === 'admin') { %>
                                                <span class="badge bg-danger rounded-pill"><i class="fas fa-user-shield me-1"></i> Quản trị viên</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary rounded-pill"><i class="fas fa-user me-1"></i> Khách hàng</span>
                                            <% } %>
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a href="/admin/admin_users/edit/<%= user._id %>" class="btn btn-sm btn-outline-primary" title="Sửa / Phân quyền"><i class="fas fa-user-edit"></i></a>
                                                
                                                <% if (user.username !== session.username) { %>
                                                    <form action="/admin/admin_users/delete/<%= user._id %>" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn tài khoản này không?');">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa tài khoản"><i class="fas fa-trash-alt"></i></button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>