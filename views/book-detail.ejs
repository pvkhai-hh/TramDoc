<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title><%= book.title %> - Trạm Đọc</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body { background-color: #f5f5f5; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .price-text { color: #d0021b; font-size: 28px; font-weight: bold; }
    </style>
</head>
<body>

    <div class="container mt-4 mb-3">
        <a href="/" class="text-decoration-none text-success fw-bold"><i class="fas fa-arrow-left"></i> Quay lại trang chủ</a>
    </div>

    <div class="container bg-white p-4 rounded shadow-sm">
        <div class="row">
            <div class="col-md-4 text-center">
                <img src="<%= book.image %>" alt="<%= book.title %>" class="img-fluid rounded border" style="max-height: 400px; object-fit: contain;">
            </div>

            <div class="col-md-8">
                <h2 class="fw-bold mb-2"><%= book.title %></h2>
                <p class="text-muted mb-2">Thể loại: <strong><%= book.author %></strong></p>
                <p class="text-muted mb-4">Tác giả: <strong><%= book.tacGia %></strong></p>
                
                <div class="bg-light p-3 rounded mb-3">
                    <span class="price-text"><%= book.price.toLocaleString('vi-VN') %> ₫</span>
                </div>

                <p class="mb-4" style="line-height: 1.8;">
                    <strong>Mô tả nội dung:</strong><br>
                    <%= book.description || 'Chưa có mô tả cho quyển sách này.' %>
                </p>

                <p>Kho còn: <span class="badge bg-success"><%= book.stock %></span> | Đã bán: <%= book.sold || 0 %></p>

                <hr>

                <form action="/add-to-cart" method="POST" class="d-flex align-items-center gap-3">
                    <input type="hidden" name="bookId" value="<%= book._id %>">
                    
                    <div class="input-group" style="width: 130px;">
                        <span class="input-group-text">SL:</span>
                        <input type="number" name="quantity" class="form-control text-center" value="1" min="1" max="<%= book.stock %>">
                    </div>

                    <% if (typeof session !== 'undefined' && session.userId) { %>
                        <button type="submit" name="action" value="add" class="btn btn-outline-success px-4 py-2 fw-bold">
                            <i class="fas fa-cart-plus me-2"></i>Thêm Vào Giỏ
                        </button>
                        <button type="submit" name="action" value="buy" class="btn btn-danger px-4 py-2 fw-bold">
                            Mua Ngay
                        </button>
                    <% } else { %>
                        <a href="/dangnhap" class="btn btn-secondary px-4 py-2 fw-bold">
                            <i class="fas fa-lock me-2"></i>Đăng Nhập Để Mua Hàng
                        </a>
                    <% } %>
                </form>

            </div>
            <div class="add-comment mt-4 mb-5">
                <h4>Viết bình luận của bạn</h4>
                
                <% if (session && session.userId) { %>
                    
                    <% if (hasPurchased) { %>
                        <form action="/book/<%= book._id %>/comment" method="POST">
                            <div class="mb-3 mt-3">
                                <textarea name="content" class="form-control" rows="3" placeholder="Chia sẻ cảm nghĩ của bạn về cuốn sách (Chất lượng giấy, nội dung...)" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-success">Gửi Bình Luận</button>
                        </form>
                    
                    <% } else { %>
                        <div class="alert alert-warning mt-3" role="alert">
                            <i class="fas fa-lock"></i> Bạn cần mua và nhận hàng thành công cuốn sách này mới có quyền gửi bình luận nhé!
                        </div>
                    <% } %>

                <% } else { %>
                    <div class="alert alert-info mt-3" role="alert">
                        Vui lòng <a href="/dangnhap" class="alert-link text-decoration-underline">Đăng nhập</a> để có thể bình luận.
                    </div>
                <% } %>
            </div>
            <div class="comments-section mt-5">
                <h3>Bình luận từ độc giả</h3>
                <hr>
                <% if (book.comments && book.comments.length > 0) { %>
                    <% book.comments.forEach(comment => { %>
                        <div class="comment mb-3 p-3 bg-light rounded">
                            <strong><i class="fas fa-user"></i> <%= comment.user %></strong>
                            <span class="text-muted" style="font-size: 0.8rem;">
                                - <%= comment.date.toLocaleDateString('vi-VN') %>
                            </span>
                            <p class="mt-2 mb-0"><%= comment.content %></p>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p>Chưa có bình luận nào. Hãy là người đầu tiên nhận xét về cuốn sách này!</p>
                <% } %>
            </div>
            
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <% if (typeof successMsg !== 'undefined' && successMsg) { %>
        <script>
            Swal.fire({ position: 'center', icon: 'success', title: '<%= successMsg %>', showConfirmButton: false, timer: 1500 });
        </script>
    <% } %>
</body>
</html>