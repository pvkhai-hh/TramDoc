<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Xác thực - Trạm Đọc</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Segoe+UI:wght@400;600;700&display=swap');
        
        * { box-sizing: border-box; }
        body {
            background: #f4f7f6; display: flex; justify-content: center; align-items: center;
            flex-direction: column; font-family: 'Segoe UI', sans-serif; height: 100vh; margin: 0;
        }

        h1 { font-weight: bold; margin: 0; color: #198754; font-size: 28px; }
        p { font-size: 14px; font-weight: 100; line-height: 20px; letter-spacing: 0.5px; margin: 20px 0 30px; }
        span { font-size: 12px; margin-top: 10px; margin-bottom: 15px; color: #777; }
        a.forgot-pass { color: #555; font-size: 13px; text-decoration: none; margin: 15px 0; transition: 0.3s; }
        a.forgot-pass:hover { color: #198754; text-decoration: underline; }

        button {
            border-radius: 25px; border: 1px solid #198754; background-color: #198754; color: #FFFFFF;
            font-size: 13px; font-weight: bold; padding: 12px 45px; letter-spacing: 1px; text-transform: uppercase; 
            transition: 0.3s ease-in-out; cursor: pointer; box-shadow: 0 4px 6px rgba(25,135,84,0.2);
        }
        button:hover { background-color: #146c43; transform: translateY(-2px); box-shadow: 0 6px 12px rgba(25,135,84,0.3); }
        button:active { transform: scale(0.95); }
        button:focus { outline: none; }
        button.ghost { background-color: transparent; border-color: #FFFFFF; color: #fff; box-shadow: none; }
        button.ghost:hover { background-color: rgba(255,255,255,0.2); }
        
        form {
            background-color: #FFFFFF; display: flex; align-items: center; justify-content: center;
            flex-direction: column; padding: 0 40px; height: 100%; text-align: center;
        }

        .input-group { position: relative; margin: 8px 0; width: 100%; }
        .input-group i { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #aaa; transition: 0.3s;}
        .input-group input {
            background-color: #f4f7f6; border: 1px solid #e0e0e0; padding: 12px 15px 12px 45px; 
            margin: 0; width: 100%; border-radius: 8px; outline: none; transition: 0.3s; font-family: inherit;
        }
        .input-group input:focus { background-color: #fff; border-color: #198754; box-shadow: 0 0 0 3px rgba(25,135,84,0.1); }
        .input-group input:focus + i, .input-group input:not(:placeholder-shown) + i { color: #198754; }

        .social-container { margin: 15px 0; }
        .social-container a {
            border: 1px solid #ddd; border-radius: 50%; display: inline-flex; justify-content: center; 
            align-items: center; margin: 0 5px; height: 40px; width: 40px; text-decoration: none; 
            color: #555; transition: 0.3s;
        }
        .social-container a:hover { background-color: #198754; color: white; border-color: #198754; }
        
        .container {
            background-color: #fff; border-radius: 20px; box-shadow: 0 14px 28px rgba(0,0,0,0.1), 0 10px 10px rgba(0,0,0,0.05);
            position: relative; overflow: hidden; width: 850px; max-width: 100%; min-height: 580px;
        }
        
        .form-container { position: absolute; top: 0; height: 100%; transition: all 0.6s ease-in-out; }
        .sign-in-container { left: 0; width: 50%; z-index: 2; }
        .container.right-panel-active .sign-in-container { transform: translateX(100%); }
        .sign-up-container { left: 0; width: 50%; opacity: 0; z-index: 1; }
        
        .container.right-panel-active .sign-up-container { 
            transform: translateX(100%); opacity: 1; z-index: 5; animation: show 0.6s; 
        }
        
        @keyframes show {
            0%, 49.99% { opacity: 0; z-index: 1; }
            50%, 100% { opacity: 1; z-index: 5; }
        }
        
        /* Overlay */
        .overlay-container {
            position: absolute; top: 0; left: 50%; width: 50%; height: 100%; overflow: hidden;
            transition: transform 0.6s ease-in-out; z-index: 100;
        }
        .container.right-panel-active .overlay-container { transform: translateX(-100%); }
        
        .overlay {
            background: url('https://images.unsplash.com/photo-1544947950-fa07a98d237f?q=80&w=800&auto=format&fit=crop') no-repeat center;
            background-size: cover; color: #FFFFFF; position: relative; left: -100%; height: 100%; width: 200%;
            transform: translateX(0); transition: transform 0.6s ease-in-out;
        }
        .overlay::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(21, 76, 42, 0.75); 
        }
        .container.right-panel-active .overlay { transform: translateX(50%); }
        
        .overlay-panel {
            position: absolute; display: flex; align-items: center; justify-content: center;
            flex-direction: column; padding: 0 40px; text-align: center; top: 0; height: 100%; width: 50%;
            transform: translateX(0); transition: transform 0.6s ease-in-out; z-index: 1;
        }
        .overlay-left { transform: translateX(-20%); }
        .container.right-panel-active .overlay-left { transform: translateX(0); }
        .overlay-right { right: 0; transform: translateX(0); }
        .container.right-panel-active .overlay-right { transform: translateX(20%); }
        
        .alert-error {
            background: #ffebee; color: #c62828; padding: 10px; border-radius: 8px; 
            width: 100%; margin-bottom: 15px; font-size: 13px; font-weight: 600; border-left: 4px solid #c62828;
        }
        
        .back-home { 
            position: absolute; top: 25px; left: 30px; color: #198754; text-decoration: none; 
            font-weight: bold; z-index: 10; font-size: 14px; padding: 10px 20px; 
            background: white; border-radius: 25px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); transition: 0.3s;
        }
        .back-home:hover { transform: translateY(-3px); box-shadow: 0 6px 15px rgba(0,0,0,0.15); color: #146c43; }
    </style>
</head>
<body>
    <a href="/" class="back-home"><i class="fas fa-arrow-left me-2"></i>Trang chủ</a>
    
    <div class="container <%= (typeof active !== 'undefined' && active === 'register') ? 'right-panel-active' : '' %>" id="container">
        
        <div class="form-container sign-up-container">
            <form action="/dangky" method="POST">
                <h1>Tạo Tài Khoản</h1>
                <div class="social-container">
                    <a href="#" class="social"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="social"><i class="fab fa-google"></i></a>
                    <a href="#" class="social"><i class="fab fa-twitter"></i></a>
                </div>
                <span>Hoặc đăng ký bằng Email của bạn</span>
                
                <div class="input-group">
                    <input type="text" name="HoVaTen" placeholder="Họ và Tên" required />
                    <i class="fas fa-id-card"></i>
                </div>
                <div class="input-group">
                    <input type="email" name="Email" placeholder="Địa chỉ Email" required />
                    <i class="fas fa-envelope"></i>
                </div>
                <div class="input-group">
                    <input type="text" name="TenDangNhap" placeholder="Tên đăng nhập" required />
                    <i class="fas fa-user"></i>
                </div>
                <div class="input-group">
                    <input type="password" name="MatKhau" placeholder="Mật khẩu" required />
                    <i class="fas fa-lock"></i>
                </div>
                
                <button type="submit" style="margin-top: 15px;">ĐĂNG KÝ NGAY</button>
            </form>
        </div>
        
        <div class="form-container sign-in-container">
            <form action="/dangnhap" method="POST">
                <h1>Đăng Nhập</h1>
                <div class="social-container">
                    <a href="#" class="social"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="social"><i class="fab fa-google"></i></a>
                    <a href="#" class="social"><i class="fab fa-twitter"></i></a>
                </div>
                <span>Hoặc sử dụng tài khoản Trạm Đọc</span>
                
                <% if (typeof session !== 'undefined' && session.error) { %>
                    <div class="alert-error"><i class="fas fa-exclamation-circle me-1"></i> <%= session.error %></div>
                <% } %>
                
                <div class="input-group">
                    <input type="text" name="TenDangNhap" placeholder="Tên đăng nhập" required />
                    <i class="fas fa-user"></i>
                </div>
                <div class="input-group">
                    <input type="password" name="MatKhau" placeholder="Mật khẩu" required />
                    <i class="fas fa-lock"></i>
                </div>
                
                <a href="#" class="forgot-pass">Quên mật khẩu?</a>
                <button type="submit">ĐĂNG NHẬP</button>
            </form>
        </div>
        
        <div class="overlay-container">
            <div class="overlay">
                <div class="overlay-panel overlay-left">
                    <h1 style="color: white; font-size: 36px; margin-bottom: 10px;">Mừng trở lại!</h1>
                    <p>Để tiếp tục mua sắm và đọc sách, vui lòng đăng nhập bằng thông tin cá nhân của bạn.</p>
                    <button class="ghost" id="signIn">ĐĂNG NHẬP</button>
                </div>
                <div class="overlay-panel overlay-right">
                    <h1 style="color: white; font-size: 36px; margin-bottom: 10px;">Chào bạn mới!</h1>
                    <p>Khám phá kho tàng sách vô tận bằng cách tạo ngay một tài khoản tại Trạm Đọc.</p>
                    <button class="ghost" id="signUp">ĐĂNG KÝ</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        const signUpButton = document.getElementById('signUp');
        const signInButton = document.getElementById('signIn');
        const container = document.getElementById('container');

        signUpButton.addEventListener('click', () => {
            container.classList.add("right-panel-active");
        });

        signInButton.addEventListener('click', () => {
            container.classList.remove("right-panel-active");
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <% if (typeof successMsg !== 'undefined' && successMsg) { %>
        <script>
            Swal.fire({ 
                position: 'center', 
                icon: 'success', 
                title: 'Tuyệt vời!', 
                text: '<%= successMsg %>', 
                showConfirmButton: false, 
                timer: 2000 
            });
        </script>
    <% } %>

    <% if (typeof errorMsg !== 'undefined' && errorMsg) { %>
        <script>
            Swal.fire({ 
                icon: 'error', 
                title: 'Lỗi đăng nhập', 
                text: '<%= errorMsg %>' 
            });
        </script>
    <% } %>

</body>
</html>