<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Hóa đơn #<%= order._id.toString().slice(-6).toUpperCase() %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style> 
        body { background-color: #eee; font-family: 'Segoe UI', sans-serif; } 
        .invoice-box { background: #fff; max-width: 800px; margin: 20px auto; padding: 40px; box-shadow: 0 0 15px rgba(0,0,0,0.1); border-top: 6px solid #198754; }
    </style>
</head>
<body>
    <div class="container d-print-none mt-4 text-center">
        <a href="/orders" class="text-decoration-none text-success fw-bold"><i class="fas fa-arrow-left"></i> Trở về danh sách đơn hàng</a>
    </div>

    <div class="container">
        <div class="invoice-box rounded-3">
            <div class="row border-bottom pb-4 mb-4 align-items-center">
                <div class="col-sm-6">
                    <h2 class="text-success fw-bold mb-0"><i class="fas fa-book-reader me-2"></i>TRẠM ĐỌC</h2>
                    <p class="text-muted mb-0 mt-1">Nhà sách đám mây số 1 Việt Nam</p>
                </div>
                <div class="col-sm-6 text-sm-end mt-3 mt-sm-0">
                    <h4 class="fw-bold mb-2">HÓA ĐƠN BÁN HÀNG</h4>
                    <p class="mb-0 text-muted">Mã ĐH: <strong>#<%= order._id.toString().slice(-6).toUpperCase() %></strong></p>
                    <p class="mb-0 text-muted">Ngày lập: <%= order.orderDate.toLocaleDateString('vi-VN') %></p>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-sm-12 p-3 bg-light rounded border">
                    <h6 class="fw-bold text-secondary text-uppercase mb-3 border-bottom pb-2">Thông tin người nhận</h6>
                    <p class="mb-1"><strong>Họ và tên:</strong> <%= order.customerName %></p>
                    <p class="mb-1"><strong>Điện thoại:</strong> <%= order.phone %></p>
                    <p class="mb-0"><strong>Địa chỉ:</strong> <%= order.address %></p>
                </div>
            </div>

            <table class="table table-bordered mb-4">
                <thead class="table-success text-center">
                    <tr>
                        <th style="width: 5%">STT</th>
                        <th class="text-start">Tên sách</th>
                        <th style="width: 15%">Đơn giá</th>
                        <th style="width: 10%">SL</th>
                        <th style="width: 20%">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    <% order.items.forEach((item, index) => { %>
                        <tr>
                            <td class="text-center"><%= index + 1 %></td>
                            <td><%= item.title %></td>
                            <td class="text-end"><%= item.price.toLocaleString('vi-VN') %> ₫</td>
                            <td class="text-center"><%= item.quantity %></td>
                            <td class="text-end fw-bold"><%= (item.price * item.quantity).toLocaleString('vi-VN') %> ₫</td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>

            <div class="row mt-4">
                <div class="col-sm-7">
                    <p class="text-muted small fst-italic">Cảm ơn bạn đã mua sắm tại Trạm Đọc.<br>Hy vọng bạn sẽ có những giây phút tuyệt vời cùng những trang sách!</p>
                </div>
                <div class="col-sm-5 text-end">
                    <h5 class="fw-bold d-flex justify-content-between">
                        <span>Tổng cộng:</span> 
                        <span class="text-danger fs-4"><%= order.totalAmount.toLocaleString('vi-VN') %> ₫</span>
                    </h5>
                </div>
            </div>
            
            <div class="text-center mt-5 d-print-none border-top pt-4">
                <button onclick="window.print()" class="btn btn-success px-4 rounded-pill fw-bold">
                    <i class="fas fa-print me-2"></i>In hóa đơn này
                </button>
            </div>
        </div>
    </div>
</body>
</html>