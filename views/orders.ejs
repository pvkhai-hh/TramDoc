<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đơn hàng của tôi - Trạm Đọc</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style> body { background-color: #f4f7f6; font-family: 'Segoe UI', sans-serif; } </style>
</head>
<body>
    <div class="container mt-5 mb-5">
        <a href="/" class="text-decoration-none text-success fw-bold mb-3 d-inline-block"><i class="fas fa-arrow-left"></i> Về trang chủ</a>
        
        <h2 class="fw-bold mb-4 text-success"><i class="fas fa-shopping-bag me-2"></i>Đơn hàng của tôi</h2>

        <% if (orders.length === 0) { %>
            <div class="bg-white rounded-4 shadow-sm p-5 text-center">
                <h5 class="text-muted mb-3">Bạn chưa có đơn hàng nào.</h5>
                <a href="/" class="btn btn-success px-4 rounded-pill">Mua sắm ngay</a>
            </div>
        <% } else { %>
            <div class="bg-white rounded-4 shadow-sm p-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn hàng</th>
                                <th>Ngày đặt</th>
                                <th>Người nhận</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th class="text-center">Hóa đơn</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orders.forEach(order => { %>
                                <tr>
                                    <td><strong class="text-secondary">#<%= order._id.toString().slice(-6).toUpperCase() %></strong></td>
                                    <td><%= order.orderDate.toLocaleString('vi-VN') %></td>
                                    <td><%= order.customerName %></td>
                                    <td class="text-danger fw-bold"><%= order.totalAmount.toLocaleString('vi-VN') %> ₫</td>
                                    <td>
                                        <% if (order.status === 'Chờ duyệt' || order.status === 'Đang chờ duyệt') { %>
                                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="fas fa-clock me-1"></i>Chờ duyệt</span>
                                        <% } else if (order.status === 'Đã duyệt' || order.status === 'Đang giao') { %>
                                            <span class="badge bg-success px-3 py-2 rounded-pill"><i class="fas fa-check-circle me-1"></i>Đã duyệt</span>
                                        <% } else if (order.status === 'Hoàn thành' || order.status === 'Đã hoàn thành') { %>
                                            <span class="badge bg-primary px-3 py-2 rounded-pill"><i class="fas fa-box-open me-1"></i>Hoàn thành</span>
                                        <% } else if (order.status === 'Đã hủy') { %>
                                            <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="fas fa-times-circle me-1"></i>Đã hủy</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary px-3 py-2 rounded-pill"><%= order.status %></span>
                                        <% } %>
                                    </td>
                                    
                                    <td class="text-center">
                                        <% if (order.status === 'Chờ duyệt' || order.status === 'Đang chờ duyệt') { %>
                                            <div class="d-flex gap-2 justify-content-center">
                                                <button class="btn btn-sm btn-secondary rounded-pill" disabled title="Admin đang duyệt đơn"><i class="fas fa-spinner fa-spin"></i> Xử lý</button>
                                                
                                                <form action="/cancel-order/<%= order._id %>" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không? Sách sẽ được hoàn lại kho.')">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill fw-bold">
                                                        <i class="fas fa-times me-1"></i> Hủy
                                                    </button>
                                                </form>
                                            </div>
                                        <% } else if (order.status === 'Đã hủy') { %>
                                            <span class="text-muted small"><i class="fas fa-ban"></i> Đã hủy</span>
                                        <% } else { %>
                                            <a href="/invoice/<%= order._id %>" class="btn btn-sm btn-outline-success rounded-pill fw-bold">
                                                <i class="fas fa-file-invoice me-1"></i> Xem hóa đơn
                                            </a>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>
    </div>
</body>
</html>